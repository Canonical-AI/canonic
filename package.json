{
  "name": "canonic",
  "version": "0.0.32-alpha",
  "description": "Local-first markdown document editor with git versioning",
  "author": "John Azzinaro <johnjAzzinaro@gmail.com>",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite --port 5173\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "build:mac": "vite build && electron-builder --mac",
    "build:linux": "vite build && electron-builder --linux",
    "build:flatpak": "vite build && electron-builder --linux flatpak --arm64",
    "build:win": "vite build && electron-builder --win",
    "preview": "vite preview",
    "electron": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@milkdown/core": "^7.20.0",
    "@milkdown/plugin-block": "^7.20.0",
    "@milkdown/plugin-history": "^7.20.0",
    "@milkdown/plugin-listener": "^7.20.0",
    "@milkdown/preset-commonmark": "^7.20.0",
    "@milkdown/preset-gfm": "^7.20.0",
    "@milkdown/theme-nord": "^7.20.0",
    "@milkdown/utils": "^7.20.0",
    "@milkdown/vue": "^7.20.0",
    "@prosemirror-adapter/vue": "^0.4.6",
    "@vueuse/core": "^10.11.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "bonjour-service": "^1.2.1",
    "call-bind-apply-helpers": "^1.0.2",
    "call-bound": "^1.0.4",
    "chokidar": "^4.0.3",
    "dunder-proto": "^1.0.1",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "flexsearch": "^0.8.212",
    "get-intrinsic": "^1.3.0",
    "get-proto": "^1.0.1",
    "isomorphic-git": "^1.27.2",
    "lucide-vue-next": "^1.0.0",
    "marked": "^15.0.12",
    "mermaid": "^11.14.0",
    "node-fetch": "^3.3.2",
    "node-pty": "^1.1.0",
    "pinia": "^2.2.6",
    "semver": "^7.8.0",
    "unist-util-visit": "^5.1.0",
    "uuid": "^14.0.0",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "concurrently": "^9.1.2",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "happy-dom": "^20.9.0",
    "vite": "^6.0.5",
    "vitest": "^4.1.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "ai.canonic.app",
    "productName": "Canonic",
    "icon": "build/icons/icon.png",
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown",
        "role": "Editor"
      }
    ],
    "asar": true,
    "afterPack": "./afterPack.js",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "publish": {
      "provider": "github",
      "owner": "Canonical-AI",
      "repo": "canonic"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "artifactName": "${name}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "maintainer": "John Azzinaro <johnjAzzinaro@gmail.com>",
      "artifactName": "${name}-${arch}.${ext}",
      "category": "Office",
      "target": [
        "AppImage",
        "flatpak",
        "pacman",
        "tar.gz"
      ]
    },
    "flatpak": {
      "runtime": "org.freedesktop.Platform",
      "runtimeVersion": "24.08",
      "sdk": "org.freedesktop.Sdk",
      "base": "org.electronjs.Electron2.BaseApp",
      "baseVersion": "24.08",
      "finishArgs": [
        "--share=network",
        "--filesystem=home",
        "--socket=wayland",
        "--socket=x11",
        "--share=ipc",
        "--device=dri"
      ]
    },
    "win": {
      "artifactName": "${name}-${arch}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "asarUnpack": [
      "**/node_modules/isomorphic-git/**/*",
      "**/node_modules/call-bind-apply-helpers/**/*",
      "**/node_modules/call-bound/**/*",
      "**/node_modules/dunder-proto/**/*",
      "**/node_modules/get-intrinsic/**/*",
      "**/node_modules/get-proto/**/*"
    ],
    "extraResources": [
      {
        "from": "bin/",
        "to": "bin/",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
